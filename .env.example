# Copy to .env and adjust.
# After `docker compose up -d`, this URL matches docker-compose defaults:

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/multidoc

# --- Optional: MinIO / S3 for *raw uploaded files* (PDFs, etc.) ---
# If unset, files stay on local disk under ``uploads/``. With ``docker compose up -d``,
# use the same MinIO as the stack. Host port defaults to 9000; if that port is taken, set in `.env`:
# MINIO_PUBLISH_PORT=9002
# MINIO_CONSOLE_PUBLISH_PORT=9003
# MINIO_ENDPOINT=localhost:9002   # must match MINIO_PUBLISH_PORT
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=rag-lab-ingest
# MINIO_UPLOAD_PREFIX=multidoc-research
# MINIO_USE_SSL=false  → http://host:9000 (typical local MinIO)
# MINIO_USE_SSL=true   → https://…
# Trust MinIO TLS with a PEM (CA or MinIO ``public.crt``); alias: MINIO_TLS_CA
# MINIO_CA_BUNDLE=/path/to/public.crt
# Or disable verify (dev only): MINIO_CERT_CHECK=false
# MINIO_CERT_CHECK=false
# Boto3 default; set if your MinIO uses another region
# MINIO_REGION=us-east-1
# If auto-create keeps failing, create the bucket in the MinIO UI then:
# MINIO_SKIP_BUCKET_CREATE=true

# --- Milvus (vector database) ---
# Start stack (Postgres + MinIO + Milvus): `docker compose up -d` (see README)
MILVUS_URI=http://127.0.0.1:19530
# Optional: Zilliz Cloud token or Milvus auth
# MILVUS_TOKEN=
# MILVUS_DB_NAME=
# If you see MilvusException code=2, try unlimited gRPC wait: MILVUS_TIMEOUT_SEC=none
# MILVUS_TIMEOUT_SEC=120
# MILVUS_COLLECTION_CATALOG=multidoc_catalog
# MILVUS_COLLECTION_CHUNKS=multidoc_chunks

# --- Embeddings (must match at ingest + query; stored in Milvus) ---
# ollama (default) or nvidia (NeMo Retriever–compatible NVIDIA embedding API; same models as many NeMo pipelines)
EMBEDDING_PROVIDER=ollama
OLLAMA_EMBED_MODEL=nomic-embed-text

# NVIDIA embeddings (when EMBEDDING_PROVIDER=nvidia): get a key at https://build.nvidia.com/
# NVIDIA_API_KEY=
# NVIDIA_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5

# --- Chat LLM (summaries + synthesis) ---
# ollama (default), gemini, or zai (GLM via zai-sdk)
LLM_PROVIDER=ollama

# Ollama (local): requires `ollama serve` and pulled models
OLLAMA_CHAT_MODEL=llama3.2

# Gemini: set LLM_PROVIDER=gemini and one of these API keys (Google AI Studio)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Optional model name (default gemini-2.0-flash)
# GEMINI_MODEL=

# Z.ai (GLM): set LLM_PROVIDER=zai and:
# ZAI_API_KEY=
# Optional: default glm-4.7-flash (confirm id in Z.ai console if calls fail)
# ZAI_CHAT_MODEL=glm-4.7-flash
# Optional base URL (overseas default in SDK; mainland often https://open.bigmodel.cn/api/paas/v4/)
# ZAI_BASE_URL=

# Chunks passed to the answer LLM per document (higher = more context for long books; costs more tokens)
# CHUNK_TOP_K=8

# Agent routing: summary vectors → chunk retrieval
# CATALOG_ROUTE_TOP_K=5
# CATALOG_ROUTE_OVERFETCH=48
# Drop docs whose summary L2 is not within this *additive* slack of the best hit (excludes irrelevant runner-ups).
# CATALOG_ROUTE_L2_MARGIN=0.22
# If the *best* match is still this weak, treat query as unrelated → retrieve nothing (empty = disabled; tune to your embeddings).
# CATALOG_ROUTE_MAX_BEST_L2=
# Hard ceiling on any single doc’s summary L2 (empty = no extra per-doc cap)
# CATALOG_ROUTE_MAX_L2=

# Optional paths
# UPLOADS_DIR=/path/to/uploads

# Print LangGraph per-node trace to the console (route / retrieve / synthesize)
# AGENT_TRACE_PRINT=1
