# Copy to .env and adjust.
# After `docker compose up -d`, this URL matches docker-compose defaults:

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/multidoc

# --- Chat LLM (summaries + synthesis) ---
# ollama (default), gemini, or zai (GLM via zai-sdk)
LLM_PROVIDER=ollama

# Ollama (local): requires `ollama serve` and pulled models
OLLAMA_CHAT_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini: set LLM_PROVIDER=gemini and one of these API keys (Google AI Studio)
# GOOGLE_API_KEY=
# GEMINI_API_KEY=
# Optional model name (default gemini-2.0-flash)
# GEMINI_MODEL=

# Z.ai (GLM): set LLM_PROVIDER=zai and:
# ZAI_API_KEY=
# Optional: default glm-4.7-flash (confirm id in Z.ai console if calls fail)
# ZAI_CHAT_MODEL=glm-4.7-flash
# Optional base URL (overseas default in SDK; mainland often https://open.bigmodel.cn/api/paas/v4/)
# ZAI_BASE_URL=

# Embeddings always use Ollama (must match existing FAISS indexes)

# Chunks passed to the answer LLM per document (higher = more context for long books; costs more tokens)
# CHUNK_TOP_K=8

# Optional: use IndexIVFPQ only when at least this many summary vectors exist (else Flat L2).
# CATALOG_MIN_VECTORS_IVFPQ=256

# Agent routing: summary FAISS → chunk retrieval
# CATALOG_ROUTE_TOP_K=5
# CATALOG_ROUTE_OVERFETCH=48
# Drop docs whose summary L2 is not within this *additive* slack of the best hit (excludes irrelevant runner-ups).
# CATALOG_ROUTE_L2_MARGIN=0.22
# If the *best* match is still this weak, treat query as unrelated → retrieve nothing (empty = disabled; tune to your embeddings).
# CATALOG_ROUTE_MAX_BEST_L2=
# Hard ceiling on any single doc’s summary L2 (empty = no extra per-doc cap)
# CATALOG_ROUTE_MAX_L2=

# Optional paths
# UPLOADS_DIR=/path/to/uploads
# CATALOG_STORE_DIR=/path/to/catalog_store

# Print LangGraph per-node trace to the console (route / retrieve / synthesize)
# AGENT_TRACE_PRINT=1
